{
  "name": "olow-ts",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-messenger AI chatbot engine — monorepo",
  "type": "module",
  "workspaces": [
    "packages/*",
    "app"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "dev": "npm run dev --workspace=olow-app",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'packages/*/src/**/*.ts' 'apps/*/src/**/*.ts'",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' 'apps/*/src/**/*.ts' --fix"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "tsx": "^4.19.4",
    "@types/node": "^22.15.29",
    "vitest": "^3.2.3",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "eslint": "^9.28.0"
  }
}
